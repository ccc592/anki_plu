{
  "name": "anki-assistant-extension-tests",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Testing harness for the Anki Assistant Chrome extension (Vitest + Playwright)",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "playwright:install": "npx playwright install",
    "msw:init": "msw init public --save",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "msw": "^2.3.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.9",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0",
    "prettier": "^3.3.2"
  }
}