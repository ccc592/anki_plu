{
  "manifest_version": 3,
  "name": "Anki Assistant",
  "version": "0.1.0",
  "description": "Capture web content and send curated cards to Anki.",
  "action": {
    "default_title": "Anki Assistant"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "scripting",
    "contextMenus",
    "activeTab",
    "commands"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "trigger-capture": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Capture selected content for Anki"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-CY69ezov.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/preferences-OC0DdBqU.js",
        "assets/preferences-OC0DdBqU.js.map",
        "assets/htmlCleaner-CloQSUk8.js",
        "assets/htmlCleaner-CloQSUk8.js.map",
        "assets/jsx-runtime-B0b5C804.js",
        "assets/jsx-runtime-B0b5C804.js.map",
        "assets/AppContainer-BqUgf2bg.js",
        "assets/AppContainer-BqUgf2bg.js.map",
        "assets/index.ts-BrmcbTQE.js",
        "assets/index.ts-BrmcbTQE.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
