{
  "name": "anki-assistant-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Chrome MV3 extension for converting web selections into Anki cards",
  "license": "MIT",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "dompurify": "^3.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@types/chrome": "^0.0.269",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "typescript": "^5.5.4",
    "vite": "^5.2.11",
    "@vitejs/plugin-react": "^4.3.1",
    "prettier": "^3.3.2"
  }
}